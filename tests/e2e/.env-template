# End-to-end testing configuration

# URL of the web application to test
E2E_WEB_URL=

# URL of the backend API
E2E_API_URL=

# Session secret for decrypting JWE tokens (must match the web app's SESSION_SECRET)
E2E_SESSION_SECRET=

# Base email for test users (Gmail address recommended for plus addressing)
# Test users will be created as:
#   - {base}+admin@gmail.com (admin user)
#   - {base}+user@gmail.com (standard user)
#   - {base}+newuser-{timestamp}@gmail.com (auto-generated users)
E2E_BASE_EMAIL=

# Gmail OAuth credentials for reading OTP verification emails
# See libs/google-api/README.md for setup instructions
E2E_GMAIL_CLIENT_ID=
E2E_GMAIL_CLIENT_SECRET=

# Use http://localhost:3123/oauth/callback when using `pnpm oauth:setup`
# Use https://developers.google.com/oauthplayground for manual setup
E2E_GMAIL_REDIRECT_URI=http://localhost:3123/oauth/callback

# Gmail OAuth refresh token (obtained after first authorization)
# Run `pnpm oauth:setup` to obtain this token
E2E_GMAIL_REFRESH_TOKEN=

# Optional: Authorization code for initial setup (if no refresh token yet)
# E2E_GMAIL_AUTH_CODE=
