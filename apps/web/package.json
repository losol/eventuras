{
  "name": "@eventuras/web",
  "version": "3.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build": "next build",
    "dev": "next dev",
    "generate:config-types": "tsx scripts/generate-config-types.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && prettier . --write",
    "start": "next start",
    "vercel-build": "pnpm --filter=@eventuras/web^... build && next build"
  },
  "lint-staged": {
    "**/*.(ts|tsx|js)": [
      "eslint --fix",
      "prettier --cache --write"
    ],
    "*.{css,json}": "prettier --cache --write"
  },
  "browserslist": [
    "defaults, not dead"
  ],
  "dependencies": {
    "@eventuras/app-config": "workspace:^",
    "@eventuras/core": "workspace:^",
    "@eventuras/core-nextjs": "workspace:^",
    "@eventuras/datatable": "workspace:^",
    "@eventuras/event-sdk": "workspace:^",
    "@eventuras/fides-auth-next": "workspace:*",
    "@eventuras/logger": "workspace:^",
    "@eventuras/markdown": "workspace:*",
    "@eventuras/markdown-plugin-happening": "workspace:*",
    "@eventuras/ratio-ui": "workspace:*",
    "@eventuras/ratio-ui-next": "workspace:*",
    "@eventuras/scribo": "workspace:*",
    "@eventuras/smartform": "workspace:*",
    "@react-stately/data": "^3.16.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/debug": "^4.1.13",
    "@xstate/react": "^6.1.0",
    "jose": "6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "openid-client": "^6.8.3",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-stately": "^3.46.0",
    "tailwindcss-react-aria-components": "^2.1.0",
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@eventuras/eslint-config": "workspace:*",
    "@next/bundle-analyzer": "16.2.4",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "pnpm": ">=9.0.0"
  }
}
