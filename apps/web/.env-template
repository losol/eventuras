# The .env file contains secrets, for local development copy this file to .env and fill in details
# Keep this template updated whenever you have changed environment variable names

# Never commit actual values in this file

# Application URL (e.g. http://localhost:3000)
APPLICATION_URL=

# API (server-side backend URL)
BACKEND_URL=

# OIDC Provider Configuration

# Redirect url after logging out (must be registered with your OIDC provider)
LOGOUT_URL_REDIRECT=

# OIDC Issuer URL
# Auth0: https://your-tenant.eu.auth0.com
# Authentik: https://auth.example.com/application/o/your-app/
OIDC_ISSUER=

# OIDC Client Id
OIDC_CLIENT_ID=

# OIDC Client Secret
OIDC_CLIENT_SECRET=

# OIDC API Audience (optional, for API token validation)
OIDC_API_AUDIENCE=

# Name of the ID token claim containing user roles (default: roles)
# Auth0: http://schemas.microsoft.com/ws/2008/06/identity/claims/role
# Authentik: roles
OIDC_ROLES_CLAIM=roles

# Session secret (must be a strong random string)
SESSION_SECRET=

# Eventuras Configuration

# Organization Id (to show events of, defaults to 1)
ORGANIZATION_ID=

# Debug (enable logs https://github.com/debug-js/debug) - example: eventuras:*,*api*
DEBUG=

# Default locale (en-US or nb-NO)
DEFAULT_LOCALE=

# Log level (debug, info, warn, error)
LOG_LEVEL=
