{
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "APPLICATION_URL",
        "LOGOUT_URL_REDIRECT",
        "DEFAULT_LOCALE",
        "ORGANIZATION_ID",
        "SITE_SETTINGS_URL",
        "BACKEND_URL",
        "OIDC_ISSUER",
        "OIDC_CLIENT_ID",
        "OIDC_CLIENT_SECRET",
        "OIDC_API_AUDIENCE",
        "OIDC_ROLES_CLAIM",
        "SESSION_SECRET",
        "NODE_ENV"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.production.local",
        ".env.local",
        ".env.production",
        ".env"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env.development.local",
        ".env.local",
        ".env.development",
        ".env"
      ]
    },
    "test": {}
  }
}
