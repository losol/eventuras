{
  "name": "@eventuras/idem-idp",
  "version": "0.7.12",
  "description": "Eventuras identity provider",
  "license": "GPL-3.0-or-later",
  "author": "Eventuras team",
  "type": "module",
  "main": "./dist/main.js",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "pnpm build:ui && pnpm build:backend",
    "build:backend": "tsup",
    "build:ui": "vite build",
    "db:check": "tsx --env-file=.env src/scripts/check-oidc-store.ts",
    "db:cleanup": "tsx --env-file=.env src/scripts/cleanup-oidc-store.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch --env-file=.env src/main.ts",
    "dev:ui:watch": "vite build --watch",
    "lint": "eslint .",
    "start": "node --enable-source-maps dist/main.js",
    "test": "sh -c 'export $(cat .env | xargs) && vitest run'",
    "test:coverage": "sh -c 'export $(cat .env | xargs) && vitest run --coverage'",
    "test:ui": "sh -c 'export $(cat .env | xargs) && vitest --ui'",
    "test:watch": "sh -c 'export $(cat .env | xargs) && vitest'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@eventuras/fides-auth": "workspace:*",
    "@eventuras/logger": "workspace:*",
    "@eventuras/mailer": "workspace:*",
    "@eventuras/notitia-templates": "workspace:*",
    "@eventuras/ratio-ui": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/middie": "^9.3.1",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "i18next": "^26.0.5",
    "jose": "^6.2.2",
    "oidc-provider": "^9.8.1",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eventuras/eslint-config": "workspace:*",
    "@eventuras/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "tailwindcss-react-aria-components": "^2.1.0",
    "tsup": "8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "4.60.1",
    "@rollup/rollup-linux-arm64-musl": "4.60.1",
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  }
}
