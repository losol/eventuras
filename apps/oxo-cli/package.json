{
  "name": "@eventuras/oxo-cli",
  "version": "0.0.1",
  "description": "Eventuras CLI tools",
  "keywords": [
    "oclif"
  ],
  "homepage": "https://github.com/losol/eventuras",
  "bugs": "https://github.com/losol/eventuras/issues",
  "repository": "losol/eventuras",
  "license": "MIT",
  "author": "Ole Kristian Losvik",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "oxo": "./bin/run.js"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "scripts": {
    "build": "shx rm -rf dist && tsc -b && oclif manifest",
    "lint": "eslint .",
    "prepack": "oclif manifest && oclif readme",
    "postpack": "shx rm -f oclif.manifest.json",
    "test": "vitest run",
    "posttest": "pnpm run lint",
    "test:watch": "vitest",
    "version": "oclif readme && git add README.md"
  },
  "oclif": {
    "bin": "oxo",
    "commands": "./dist/commands",
    "dirname": "oxo",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins",
      "@eventuras/docs-framework"
    ],
    "topicSeparator": " ",
    "topics": {
      "shipper": {
        "description": "Shipping and logistics integration commands"
      }
    }
  },
  "dependencies": {
    "@eventuras/docs-framework": "workspace:*",
    "@eventuras/shipper": "workspace:*",
    "@oclif/core": "^4.10.3",
    "@oclif/plugin-help": "^6.2.41",
    "@oclif/plugin-plugins": "^5.4.59"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4.1.17",
    "@types/node": "^24.12.0",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-oclif": "^6.0.154",
    "eslint-config-prettier": "^10.1.8",
    "oclif": "^4.22.96",
    "shx": "^0.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.0.0 <25.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
