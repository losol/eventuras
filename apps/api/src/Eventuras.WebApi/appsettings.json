{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Database=eventuras;Username=eventuras;Password=eventuras"
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "AllowedOrigins": ""
  },
  "FeatureManagement": {
    "UsePowerOffice": true,
    "UseStripeInvoice": false,
    "EnableApiDocs": false
  },
  "Auth": {
    "Issuer": "https://eventuras.eu.auth0.com",
    "Audience": "https://eventuras/api",
    "ClientId": "123",
    "ClientSecret": "*****",
    "ApiIdentifier": "456",
    "EnablePiiLogging": false
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Expressions"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "Eventuras.Services.Converto.ConvertoHealthCheck": "Warning",
        "Eventuras.Services.Converto.ConvertoClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"]
  },
  "Sentry": {
    "Dsn": "",
    "MinimumBreadcrumbLevel": "Information",
    "MinimumEventLevel": "Error",
    "MaxBreadcrumbs": 50
  },
  "Twilio": {
    "From": "+15017250604",
    "Sid": "ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
    "AuthToken": "auth_token"
  },
  "Converto": {
    "PdfEndpointUrl": "http://localhost:3100/v1/pdf",
    "TokenEndpointUrl": "http://localhost:3100/token",
    "ClientId": "id",
    "ClientSecret": "secret",
    "DefaultScale": 1,
    "DefaultPaperSize": "A4"
  }
}
