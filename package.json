{
  "name": "eventuras",
  "version": "0.1.1",
  "private": true,
  "license": "GPL-2.0+",
  "workspaces": [
    "apps/api",
    "apps/dev-docs",
    "apps/historia",
    "apps/idem-idp",
    "apps/web",
    "tests/e2e",
    "apps/convertoapi",
    "docs",
    "libs/**",
    "lab/**"
  ],
  "scripts": {
    "build": "turbo run build --concurrency 30",
    "build:dev": "turbo run build --filter=@eventuras/web... --concurrency 30",
    "changeset": "changeset",
    "changeset:suggest": "tsx scripts/changeset-suggest.ts --since origin/main --write",
    "changeset:tag": "changeset tag",
    "changeset:version": "changeset version",
    "clean": "pnpm clean:build && pnpm clean:deps",
    "clean:build": "npx rimraf \"**/{.next,.turbo,.vercel,dist,build,storybook-static}\" \"!**/node_modules/**\"",
    "clean:deps": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "deps:clean": "pnpm -r exec rm -rf node_modules && rm -rf node_modules pnpm-lock.yaml",
    "deps:reinstall": "pnpm run clean && pnpm run deps:sort && pnpm install",
    "deps:sort": "pnpm dlx sort-package-json '**/package.json' '!**/node_modules/**'",
    "deps:upgrade": "pnpm update -r --latest && cd apps/api && dotnet outdated --upgrade",
    "dev": "turbo dev --concurrency 30",
    "dev:web": "turbo dev --filter=@eventuras/web... --concurrency 30",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:staged": "pnpm dlx lint-staged",
    "next:clean": "npx rimraf \"**/{.next,.turbo,.vercel}\"",
    "openapi:update": "cd apps/api && pnpm openapi:update && cd ../.. && cd libs/event-sdk && pnpm build",
    "oxo": "cd apps/oxo-cli && node bin/run.js",
    "prepare": "simple-git-hooks",
    "release": "changeset version && git add . && git commit -m 'chore: version packages' && changeset tag && git push --follow-tags",
    "test": "turbo run test"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint:staged",
    "commit-msg": "npx --no -- commitlint --edit $1"
  },
  "lint-staged": {
    "**/package.json": "pnpm dlx sort-package-json",
    "**/*.{jsx,ts,tsx,cjs,mjs}": "eslint --fix"
  },
  "dependencies": {
    "turbo": "^2.9.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eventuras/eslint-config": "workspace:*",
    "@eventuras/typescript-config": "workspace:*",
    "@types/node": "^24.12.0",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@types/react",
        "@types/react-dom"
      ]
    },
    "updateConfig": {
      "ignoreDependencies": [
        "@types/node",
        "lexical",
        "@lexical/*"
      ]
    }
  }
}
