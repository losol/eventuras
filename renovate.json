{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["after 4am and before 6am every weekday", "after 6pm and before 8pm on saturday and sunday"],
  "timezone": "Europe/Oslo",
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps): ",
  "commitMessageAction": "update",
  "commitMessageSuffix": "",
  "rebaseWhen": "conflicted",
  "packageRules": [
    {
      "description": "Lexical must match Payload CMS richtext-lexical version — update manually",
      "matchPackagePatterns": ["^lexical$", "^@lexical/"],
      "enabled": false
    },
    {
      "description": "@types/node pinned to match engine requirements",
      "matchPackageNames": ["@types/node"],
      "enabled": false
    },
    {
      "description": "Group all non-major updates for api",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/api/**"],
      "groupName": "api minor/patch"
    },
    {
      "description": "Group all non-major updates per monorepo app/lib",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/web/**"],
      "groupName": "web minor/patch"
    },
    {
      "description": "Group all non-major updates for historia",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/historia/**"],
      "groupName": "historia minor/patch"
    },
    {
      "description": "Group all non-major updates for idem-idp",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/idem-idp/**"],
      "groupName": "idem-idp minor/patch"
    },
    {
      "description": "Group all non-major updates for idem-admin",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/idem-admin/**"],
      "groupName": "idem-admin minor/patch"
    },
    {
      "description": "Group all non-major updates for conductor",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/conductor/**"],
      "groupName": "conductor minor/patch"
    },
    {
      "description": "Group all non-major updates for convertoapi",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["apps/convertoapi/**"],
      "groupName": "convertoapi minor/patch"
    },
    {
      "description": "Group all non-major lib updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["libs/**"],
      "groupName": "libs minor/patch"
    },
    {
      "description": "Group all non-major test updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchFileNames": ["tests/**"],
      "groupName": "tests minor/patch"
    },
    {
      "description": "Group Payload CMS packages",
      "matchPackagePatterns": ["^payload$", "^@payloadcms/"],
      "groupName": "payload"
    },
    {
      "description": "Group ESLint packages",
      "matchPackagePatterns": ["eslint"],
      "groupName": "eslint"
    },
    {
      "description": "Group Docker base images",
      "matchDatasources": ["docker"],
      "groupName": "docker"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ]
}
