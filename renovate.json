{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "helpers:pinGitHubActionDigestsToSemver"],
  "enabledManagers": ["npm", "github-actions", "dockerfile"],
  "includePaths": [
    ".github/workflows/**",
    "apps/**",
    "libs/**",
    "lab/**",
    "tests/**",
    "package.json",
    "pnpm-workspace.yaml",
    "pnpm-lock.yaml"
  ],
  "timezone": "Europe/Oslo",
  "labels": ["dependencies"],
  "commitMessagePrefix": "chore(deps): ",
  "commitMessageAction": "update",
  "commitMessageSuffix": "",
  "rebaseWhen": "conflicted",
  "platformCommit": "enabled",
  "pruneStaleBranches": true,
  "minimumReleaseAge": "3 days",
  "prConcurrentLimit": 4,
  "branchConcurrentLimit": 1,
  "lockFileMaintenance": {
    "enabled": false
  },
  "packageRules": [
    {
      "description": "Lexical must match Payload CMS richtext-lexical — update manually",
      "enabled": false,
      "matchPackageNames": ["/^lexical$/", "/^@lexical//"]
    },
    {
      "description": "@types/node pinned to match engine requirements",
      "enabled": false,
      "matchPackageNames": ["@types/node"]
    },
    {
      "description": "Group ALL non-major npm updates into one PR",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchManagers": ["npm"],
      "groupName": "npm minor/patch"
    },
    {
      "description": "Group Payload CMS packages",
      "groupName": "payload",
      "matchPackageNames": ["/^payload$/", "/^@payloadcms//"]
    },
    {
      "description": "Group Storybook packages",
      "groupName": "storybook",
      "matchPackageNames": ["/^storybook$/", "/^@storybook//"]
    },
    {
      "description": "Group ESLint packages",
      "groupName": "eslint",
      "matchPackageNames": ["/eslint/"]
    },
    {
      "description": "Group Docker base images",
      "matchDatasources": ["docker"],
      "groupName": "docker"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    }
  ]
}
