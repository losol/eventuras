{
  "name": "@eventuras/ratio-ui",
  "version": "1.1.1",
  "homepage": "https://github.com/losol/eventuras/tree/main/libs/ratio-ui#readme",
  "bugs": {
    "url": "https://github.com/losol/eventuras/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/losol/eventuras.git",
    "directory": "libs/ratio-ui"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./core/*": {
      "types": "./dist/core/*/index.d.ts",
      "import": "./dist/core/*/index.js"
    },
    "./layout/*": {
      "types": "./dist/layout/*/index.d.ts",
      "import": "./dist/layout/*/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "import": "./dist/forms/index.js"
    },
    "./forms/*": {
      "types": "./dist/forms/*/index.d.ts",
      "import": "./dist/forms/*/index.js"
    },
    "./visuals/*": {
      "types": "./dist/visuals/*/index.d.ts",
      "import": "./dist/visuals/*/index.js"
    },
    "./pages/*": {
      "types": "./dist/pages/*/index.d.ts",
      "import": "./dist/pages/*/index.js"
    },
    "./blocks/*": {
      "types": "./dist/blocks/*/index.d.ts",
      "import": "./dist/blocks/*/index.js"
    },
    "./commerce/*": {
      "types": "./dist/commerce/*/index.d.ts",
      "import": "./dist/commerce/*/index.js"
    },
    "./toast": {
      "types": "./dist/toast/index.d.ts",
      "import": "./dist/toast/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./ratio-ui.css": "./dist/ratio-ui.css",
    "./global.css": "./dist/global.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/global.css",
    "src/tokens"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:all": "pnpm run build && pnpm run storybook:build",
    "dev": "pnpm run storybook",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "overrides": {
    "storybook": "$storybook",
    "vite": {
      "rollup": "npm:@rollup/wasm-node"
    }
  },
  "dependencies": {
    "@eventuras/logger": "workspace:*",
    "@internationalized/date": "^3.12.1",
    "@internationalized/number": "^3.6.6",
    "@react-aria/overlays": "^3.32.0",
    "@react-stately/data": "^3.16.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react-aria-components": "^1.17.0",
    "react-stately": "^3.46.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-react-aria-components": "^2.1.0"
  },
  "devDependencies": {
    "@eventuras/eslint-config": "workspace:*",
    "@eventuras/typescript-config": "workspace:*",
    "@eventuras/vite-config": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "ajv": "^8.18.0",
    "autoprefixer": "10.5.0",
    "eslint-plugin-storybook": "^10.3.5",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "react-dom": "^19.2.5",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
