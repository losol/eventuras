{
  "name": "@eventuras/lustro-search",
  "version": "2.0.0",
  "private": true,
  "description": "Full-text search abstraction powered by Orama — shared across docs, web, and other apps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./build-index": {
      "types": "./dist/build-index.d.ts",
      "import": "./dist/build-index.js"
    }
