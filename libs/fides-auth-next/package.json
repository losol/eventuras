    "@xstate/store": "^3.17.1"
  },
  "devDependencies": {
    "@eventuras/typescript-config": "workspace:*",
    "@eventuras/vite-config": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "vite": "^8.0.8",
    "xstate": "^5.30.0"
  },
  "peerDependencies": {
    "@xstate/react": "^5.0.0 || ^6.0.0",
