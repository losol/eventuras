    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "29.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.6",
    "xstate": "^5.32.2"
  },
  "peerDependencies": {
    "@xstate/react": "^5.0.0 || ^6.0.0",
    "@xstate/store": "^4.2.1",
    "@xstate/store-react": "^2.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "xstate": "^5.0.0"
