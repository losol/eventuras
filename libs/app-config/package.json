{
  "name": "@eventuras/app-config",
  "version": "0.1.3",
  "description": "Declarative environment configuration for Eventuras applications",
  "keywords": [
    "eventuras",
    "config",
    "environment",
    "validation"
  ],
  "homepage": "https://github.com/losol/eventuras/tree/main/libs/app-config#readme",
  "bugs": {
    "url": "https://github.com/losol/eventuras/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/losol/eventuras.git",
    "directory": "libs/app-config"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./clientside": {
      "types": "./dist/clientside.d.ts",
      "import": "./dist/clientside.js"
    },
    "./generator": {
      "types": "./dist/generator.d.ts",
      "import": "./dist/generator.js"
    },
    "./schema": "./schema/app-config.schema.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "generate-config-types": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eventuras/eslint-config": "workspace:*",
    "@eventuras/typescript-config": "workspace:*",
    "@eventuras/vite-config": "workspace:*",
    "@types/node": "^24.12.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
