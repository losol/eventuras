    "@types/uuid": "^11.0.0",
    "next": "^16.2.3",
    "payload": "3.83.0",
    "react": "^19.2.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
