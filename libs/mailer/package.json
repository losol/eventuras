  },
  "devDependencies": {
    "@eventuras/vite-config": "workspace:*",
    "@types/nodemailer": "^7.0.11",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
