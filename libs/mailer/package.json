{
  "name": "@eventuras/mailer",
  "version": "0.1.0",
  "description": "Email sending utility for Eventuras applications",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
