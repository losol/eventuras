{
  "name": "@eventuras/shipper",
  "version": "0.2.10",
  "private": true,
  "description": "Shipping and logistics integration library for Eventuras",
  "type": "module",
  "exports": {
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./bring-v1": {
      "types": "./dist/bring-v1/index.d.ts",
      "import": "./dist/bring-v1/index.js"
    }
  },
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "label:download": "tsx --env-file=.env scripts/download-label.ts",
    "shipment:create": "tsx --env-file=.env scripts/create-shipment.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@eventuras/fides-auth": "workspace:*",
    "@eventuras/logger": "workspace:*"
  },
  "devDependencies": {
    "@eventuras/typescript-config": "workspace:*",
    "@eventuras/vite-config": "workspace:*",
    "@vitest/ui": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
