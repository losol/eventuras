{
  "apps": {
    "api": {
      "path": "apps/api",
      "package": "@eventuras/api"
    },
    "conductor": {
      "path": "apps/conductor",
      "package": "@eventuras/conductor"
    },
    "dev-docs": {
      "path": "apps/dev-docs",
      "package": "@eventuras/dev-docs",
      "aliases": ["docsite"]
    },
    "historia": {
      "path": "apps/historia",
      "package": "@eventuras/historia",
      "aliases": ["cms", "historia-cms"]
    },
    "web": {
      "path": "apps/web",
      "package": "@eventuras/web",
      "aliases": ["frontend"]
    }
  },
  "tests": {
    "e2e": {
      "path": "tests/e2e",
      "package": "@eventuras/e2e",
      "aliases": ["e2e-tests", "playwright"]
    }
  },
  "libs": {
    "datatable": {
      "package": "@eventuras/datatable"
    },
    "docs-framework": {
      "package": "@eventuras/docs-framework"
    },
    "event-sdk": {
      "package": "@eventuras/event-sdk",
      "aliases": ["sdk"]
    },
    "google-api": {
      "package": "@eventuras/google-api",
      "aliases": ["google"]
    },
    "logger": {
      "package": "@eventuras/logger"
    },
    "mailer": {
      "package": "@eventuras/mailer"
    },
    "markdown": {
      "package": "@eventuras/markdown"
    },
    "notitia-templates": {
      "package": "@eventuras/notitia-templates",
      "aliases": ["notitia"]
    },
    "scribo": {
      "package": "@eventuras/scribo"
    },
    "shipper": {
      "package": "@eventuras/shipper"
    },
    "smartform": {
      "package": "@eventuras/smartform"
    },
    "vite-config": {
      "package": "@eventuras/vite-config",
      "aliases": ["vite"]
    }
  },
  "scopes": ["deps", "infra", "release"]
}
